{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=devtrackr_identity;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "Issuer": "DevTrackr",
    "Audience": "DevTrackr",
    "SigningKey": "devtrackr-super-secret-signing-key",
    "ExpirationMinutes": 60
  },
  "RabbitMq": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
